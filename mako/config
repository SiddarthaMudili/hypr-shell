# Mako Notification Daemon Configuration
# Theme: Gruvbox

# General settings
font=JetBrainsMono 13
markup=1
max-visible=5
sort=-time
layer=overlay
anchor=top-right
margin=8
padding=14
border-size=1
border-radius=16
background-color=#282828E8
text-color=#ebdbb2
border-color=#83a59859
progress-color=over #83a59859

# Default timeout
default-timeout=10000

# Dimensions
width=400
height=150
max-icon-size=48

# Grouping
group-by=app-name

# Urgency levels
[urgency=low]
border-color=#b8bb2659
default-timeout=5000

[urgency=normal]
border-color=#83a59859
default-timeout=10000

[urgency=critical]
border-color=#fb493499
default-timeout=0

# Icons
icons=1
icon-path=/usr/share/icons/Papirus-Dark

# Format
format=<b>%s</b>\n%b
