    local border_1=$(grep '\$border-1 = rgb(' "$theme_file" | sed 's/.*rgb(\([^)]*\)).*/\1/')
    local border_0=$(grep '\$border-0 = rgb(' "$theme_file" | sed 's/.*rgb(\([^)]*\)).*/\1/')
    
