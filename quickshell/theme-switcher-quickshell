        "$QUICKSHELL_DIR/sync-nvim-theme.sh" > /dev/null 2>&1
    fi

    # Sync btop theme
    if [[ -x "$QUICKSHELL_DIR/sync-btop-theme.sh" ]]; then
        echo "Syncing btop theme..."
        "$QUICKSHELL_DIR/sync-btop-theme.sh" > /dev/null 2>&1
    fi

    # Sync k9s skin
    if [[ -x "$QUICKSHELL_DIR/sync-k9s-theme.sh" ]]; then
        echo "Syncing k9s skin..."
        "$QUICKSHELL_DIR/sync-k9s-theme.sh" > /dev/null 2>&1
    fi

    # Sync YouTube Music Desktop App theme
    if [[ -x "$QUICKSHELL_DIR/sync-ytmusic-theme.sh" ]]; then
        echo "Syncing YouTube Music theme..."
        "$QUICKSHELL_DIR/sync-ytmusic-theme.sh" > /dev/null 2>&1
    fi

    # Create completion marker file
    echo "done" > "$HOME/.config/quickshell/.theme-switch-complete"

    echo "Theme applied successfully: $theme_name"
    echo "Updated: Quickshell, Hyprland, wofi, kitty, mako, hyprlock, GTK theme, wallpaper, Starship, Firefox, VS Code, VSCodium, Bento, Neovim, btop, k9s, YouTube Music"
    echo "GTK applications (Thunar, gnome-text-editor, waypaper) will now use matching theme"
    echo "Restart terminal (exec zsh), Neovim, Firefox/VS Code/VSCodium to see the new color scheme"
    
    # Send notification when complete
    if command -v notify-send &> /dev/null; then
        notify-send "Theme Applied: $theme_name" "All apps synced. Restart btop, k9s and YouTube Music to pick up new colors." -i preferences-desktop-theme -t 3000 2>/dev/null
    fi
}

# Show wofi theme selector
if [[ "$1" == "--wofi" ]]; then
    # Get list of available themes
    themes=()
    for theme_file in "$THEMES_DIR"/*.conf; do
        if [[ -f "$theme_file" ]]; then
            theme_name=$(basename "$theme_file" .conf)
            themes+=("$theme_name")
        fi
    done
    
    # Show wofi selector
    selected=$(printf '%s\n' "${themes[@]}" | wofi --dmenu --prompt "Select Theme:" --width 300 --height 400)
    
    if [[ -n "$selected" ]]; then
        theme_file="$THEMES_DIR/${selected}.conf"
        apply_theme "$theme_file" "$selected"
    fi
else
    echo "Quickshell Theme Switcher"
    echo "Usage: $0 --wofi"
    echo "Available themes:"
    for theme_file in "$THEMES_DIR"/*.conf; do
        if [[ -f "$theme_file" ]]; then
            theme_name=$(basename "$theme_file" .conf)
            echo "  - $theme_name"
        fi
    done
fi